`timescale 1ns / 1ps

//////////////////////////////////////////////////////////////////////////////////
// Testbench for Real-Time Smart 4-Way Traffic Light Controller
// Zybo Z7-10 Compatible Version
// countdown_timer removed for clean implementation
//////////////////////////////////////////////////////////////////////////////////

module smart_traffic_controller_tb;

////////////////////////////////////////////////////////////
// Inputs
////////////////////////////////////////////////////////////

reg clk;
reg reset;

reg north_sensor;
reg east_sensor;
reg south_sensor;
reg west_sensor;

reg emergency_vehicle;
reg pedestrian_request;
reg system_fault;

reg [1:0] time_of_day;

////////////////////////////////////////////////////////////
// Outputs
////////////////////////////////////////////////////////////

wire [2:0] N;
wire [2:0] E;
wire [2:0] S;
wire [2:0] W;

wire pedestrian_light;
wire emergency_mode;
wire system_healthy;

////////////////////////////////////////////////////////////
// DUT Instantiation
////////////////////////////////////////////////////////////

smart_traffic_controller uut (
    .clk(clk),
    .reset(reset),

    .north_sensor(north_sensor),
    .east_sensor(east_sensor),
    .south_sensor(south_sensor),
    .west_sensor(west_sensor),

    .emergency_vehicle(emergency_vehicle),
    .pedestrian_request(pedestrian_request),
    .system_fault(system_fault),

    .time_of_day(time_of_day),

    .N(N),
    .E(E),
    .S(S),
    .W(W),

    .pedestrian_light(pedestrian_light),
    .emergency_mode(emergency_mode),
    .system_healthy(system_healthy)
);

////////////////////////////////////////////////////////////
// Clock Generation
////////////////////////////////////////////////////////////

initial begin
    clk = 0;
    forever #5 clk = ~clk;
end

////////////////////////////////////////////////////////////
// Test Sequence
////////////////////////////////////////////////////////////

initial begin

    ////////////////////////////////////////////////////////
    // Initial Values
    ////////////////////////////////////////////////////////

    reset = 1;

    north_sensor = 0;
    east_sensor = 0;
    south_sensor = 0;
    west_sensor = 0;

    emergency_vehicle = 0;
    pedestrian_request = 0;
    system_fault = 0;

    time_of_day = 2'b01;   // Day Mode

    ////////////////////////////////////////////////////////
    // Reset Release
    ////////////////////////////////////////////////////////

    #20;
    reset = 0;

    ////////////////////////////////////////////////////////
    // Test 1: Normal Operation
    ////////////////////////////////////////////////////////

    #100;

    ////////////////////////////////////////////////////////
    // Test 2: Pedestrian Request
    ////////////////////////////////////////////////////////

    pedestrian_request = 1;
    #50;
    pedestrian_request = 0;

    ////////////////////////////////////////////////////////
    // Test 3: Emergency Vehicle Priority
    ////////////////////////////////////////////////////////

    #100;
    emergency_vehicle = 1;
    #60;
    emergency_vehicle = 0;

    ////////////////////////////////////////////////////////
    // Test 4: System Fault Detection
    ////////////////////////////////////////////////////////

    #100;
    system_fault = 1;
    #50;
    system_fault = 0;

    ////////////////////////////////////////////////////////
    // Test 5: Peak Hour Adaptive Timing
    ////////////////////////////////////////////////////////

    #100;
    time_of_day = 2'b10;   // Peak Hours

    ////////////////////////////////////////////////////////
    // Test 6: Night Mode
    ////////////////////////////////////////////////////////

    #150;
    time_of_day = 2'b00;   // Night Mode

    ////////////////////////////////////////////////////////
    // Finish Simulation
    ////////////////////////////////////////////////////////

    #300;
    $finish;

end

////////////////////////////////////////////////////////////
// Monitor Output
////////////////////////////////////////////////////////////

initial begin
    $monitor("TIME=%0t | N=%b E=%b S=%b W=%b | PED=%b | EMG=%b | HEALTH=%b",
              $time,
              N, E, S, W,
              pedestrian_light,
              emergency_mode,
              system_healthy);
end

endmodule
